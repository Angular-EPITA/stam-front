# STAM Frontend OpenTelemetry Configuration

# Environment
NODE_ENV=development

# OTLP Collector Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Service Configuration
OTEL_SERVICE_NAME=stam-front
OTEL_SERVICE_VERSION=20.3.1

# Tracing Configuration
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Metrics Configuration
OTEL_METRICS_EXPORTER=otlp
OTEL_METRICS_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/metrics

# Logs Configuration
OTEL_LOGS_EXPORTER=otlp
OTEL_LOGS_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/logs

# Sampling Configuration (0.0 to 1.0)
OTEL_TRACES_SAMPLER=always_on
OTEL_TRACES_SAMPLER_ARG=

# Export interval in milliseconds
OTEL_METRIC_EXPORT_INTERVAL=30000
OTEL_BATCHER_SCHEDULE_DELAY_MILLIS=5000

# Production Configuration (uncomment for production)
# NODE_ENV=production
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector.com:4318
# OTEL_TRACES_SAMPLER=parentbased_always_on
# OTEL_TRACES_SAMPLER_ARG=0.1
