{
  "name": "stam-front",
  "version": "20.3.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:local": "ng serve --proxy-config proxy.local.conf.json",
    "start:stam": "ng serve --proxy-config proxy.stam-api.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "release": "release-it --ci",
    "otel:up": "docker compose up -d",
    "otel:down": "docker compose down",
    "otel:logs": "docker compose logs -f otel-collector",
    "otel:status": "docker compose ps",
    "otel:clean": "docker compose down -v",
    "monitor": "npm run otel:up && sleep 5 && npm run start:local"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/sdk-trace-web": "^1.26.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.26.0",
    "@opentelemetry/instrumentation": "^0.52.0",
    "@opentelemetry/instrumentation-fetch": "^0.52.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.52.0",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.0",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^20.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "release-it": "^19.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.4"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(release): v${version} [skip ci]",
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "autoGenerate": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "before:bump": "echo \"Release : v${latestVersion} → v${version}\""
    }
  }
}
